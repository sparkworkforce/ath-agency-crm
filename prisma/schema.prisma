generator client {
  provider = "prisma-client"
  output   = "./generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  AGENCY
  CLIENT
}

enum AgencyPlan {
  FREE
  PROFESSIONAL
  BUSINESS
}

enum ClientStatus {
  prospecto
  en_progreso
  completado
  soporte_mensual
}

enum ClientPlatform {
  WOOCOMMERCE
  SHOPIFY
  CUSTOM
}

enum TaskStatus {
  pendiente
  en_progreso
  completado
  vencido
}

enum InvoiceStatus {
  pendiente
  pagado
  vencido
}

enum TicketStatus {
  abierto
  en_progreso
  cerrado
}

enum SnippetPlatform {
  WOOCOMMERCE
  SHOPIFY
  CUSTOM
  GENERAL
}

enum SnippetCategory {
  wrapper
  webhook
  utility
}

// ─── Agency (Tenant) ─────────────────────────────────────

model Agency {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  logoUrl          String?
  primaryColor     String?    @default("#059669")
  plan             AgencyPlan @default(FREE)
  stripeCustomerId String?    @unique
  stripeSubId      String?
  stripePriceId    String?
  subStatus        String?    // active, past_due, canceled, trialing
  subCurrentPeriodEnd DateTime?
  maxClients       Int        @default(3)
  maxUsers         Int        @default(1)
  currency         String     @default("USD")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  users    User[]
  clients  Client[]
  snippets CodeSnippet[]

  @@index([slug])
}

// ─── NextAuth Required Models (PrismaAdapter) ────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ──────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole
  agencyId      String?
  clientId      String?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  agency        Agency?       @relation(fields: [agencyId], references: [id])
  accounts      Account[]
  sessions      Session[]
  client        Client?       @relation(fields: [clientId], references: [id])
  assignedTasks Task[]        @relation("AssignedTasks")
  snippets      CodeSnippet[]
  magicLinks    MagicLink[]

  @@index([email])
  @@index([role])
  @@index([agencyId])
  @@index([clientId])
}

model MagicLink {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model LoginAttempt {
  id          String    @id @default(cuid())
  email       String    @unique
  attempts    Int       @default(0)
  lastAttempt DateTime  @default(now())
  lockedUntil DateTime?

  @@index([email])
}

model Client {
  id           String         @id @default(cuid())
  agencyId     String
  businessName String
  contactName  String
  contactEmail String
  contactPhone String?
  industry     String?
  platform     ClientPlatform
  status       ClientStatus   @default(prospecto)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  agency         Agency                @relation(fields: [agencyId], references: [id])
  users          User[]
  projects       Project[]
  invoices       Invoice[]
  tickets        SupportTicket[]
  communications Communication[]
  statusHistory  ClientStatusHistory[]

  @@index([agencyId])
  @@index([status])
  @@index([deletedAt])
  @@index([contactEmail])
}

model ClientStatusHistory {
  id        String       @id @default(cuid())
  clientId  String
  status    ClientStatus
  changedAt DateTime     @default(now())
  changedBy String

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Communication {
  id        String   @id @default(cuid())
  clientId  String
  date      DateTime
  channel   String
  summary   String
  createdBy String
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Project {
  id                      String    @id @default(cuid())
  name                    String
  clientId                String
  completionPercentage    Float     @default(0)
  estimatedCompletionDate DateTime?
  milestonesSent          Json      @default("[]")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  client Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks  Task[]
  files  ProjectFile[]
  integrationStatus IntegrationStatus?

  @@index([clientId])
}

model Task {
  id           String     @id @default(cuid())
  projectId    String
  title        String
  assignedToId String?
  dueDate      DateTime?
  status       TaskStatus @default(pendiente)
  order        Int        @default(0)
  estimatedDays Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation("AssignedTasks", fields: [assignedToId], references: [id])

  @@index([projectId])
  @@index([status])
  @@index([assignedToId])
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  fileName   String
  fileType   String
  fileSize   Int
  storageKey String
  uploadedBy String
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Invoice {
  id          String        @id @default(cuid())
  clientId    String
  totalAmount Decimal       @db.Decimal(10, 2)
  status      InvoiceStatus @default(pendiente)
  dueDate     DateTime
  isRetainer  Boolean       @default(false)
  createdBy   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  client   Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payments Payment[]
  lineItems InvoiceLineItem[]
  auditLog InvoiceAuditLog[]

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([isRetainer])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  amount      Decimal @db.Decimal(10, 2)
  order       Int     @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id         String   @id @default(cuid())
  invoiceId  String
  amount     Decimal  @db.Decimal(10, 2)
  receivedAt DateTime
  recordedBy String
  createdAt  DateTime @default(now())

  invoice  Invoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  auditLog InvoiceAuditLog[]

  @@index([invoiceId])
}

model InvoiceAuditLog {
  id         String   @id @default(cuid())
  invoiceId  String
  paymentId  String?
  action     String
  actorId    String
  beforeData Json?
  afterData  Json?
  createdAt  DateTime @default(now())

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@index([invoiceId])
  @@index([paymentId])
}

model SupportTicket {
  id          String       @id @default(cuid())
  clientId    String
  title       String
  description String
  status      TicketStatus @default(abierto)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status])
}

model CodeSnippet {
  id          String          @id @default(cuid())
  agencyId    String
  title       String
  description String
  code        String          @db.Text
  language    String
  platform    SnippetPlatform
  category    SnippetCategory
  authorId    String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([agencyId])
  @@index([platform])
  @@index([category])
  @@index([authorId])
}

enum ATHAccountStatus {
  pending
  submitted
  approved
  active
  rejected
}

model IntegrationStatus {
  id              String           @id @default(cuid())
  projectId       String           @unique
  athAccountStatus ATHAccountStatus @default(pending)
  athPublicToken  String?
  environment     String           @default("sandbox") // sandbox | production
  webhookUrl      String?
  webhookVerified Boolean          @default(false)
  testTransactionAt DateTime?
  testTransactionOk Boolean?
  goLiveAt        DateTime?
  notes           String?
  updatedAt       DateTime         @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
