# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Database (Supabase)
# Runtime — connection pooler (port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
# Migrations only — direct connection (port 5432), configured in prisma.config.ts
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Cron (generate a random 32+ char string)
CRON_SECRET=

# Agency name (used in email templates)
NEXT_PUBLIC_AGENCY_NAME=

# Seed — only for development/initial setup
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
