# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Database (Supabase)
# Runtime — connection pooler (port 6543)
# Append &statement_timeout=30000 to enforce a 30s query timeout in PostgreSQL
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&statement_timeout=30000
# Migrations only — direct connection (port 5432)
DIRECT_URL=postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres

# Resend (Email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Supabase Storage
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (Billing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PROFESSIONAL=price_xxx
STRIPE_PRICE_BUSINESS=price_xxx

# Upstash Redis (Rate Limiting — optional in dev)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Sentry (Error Monitoring — optional in dev)
NEXT_PUBLIC_SENTRY_DSN=

# Cron (generate a random 32+ char string)
CRON_SECRET=

# Seed — only for development/initial setup
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# Google OAuth (optional — enables "Continue with Google" on login/register)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Plausible Analytics (optional — privacy-first analytics)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# WhatsApp Business Cloud API (optional)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
